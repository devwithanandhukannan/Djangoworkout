# -----------------------------------------------------------------
# 1. Byte-compiled / Optimized / Temporary files
# -----------------------------------------------------------------
*.pyc
__pycache__/
*~
*.swp
*.bak
.DS_Store # Mac operating system files

# -----------------------------------------------------------------
# 2. Virtual Environment
# -----------------------------------------------------------------
# The directory name of the virtual environment used in your path:
env/
venv/
.venv/

# -----------------------------------------------------------------
# 3. Operating System Files
# -----------------------------------------------------------------
.DS_Store
.vscode/ # Optional: If you want to ignore VS Code settings

# -----------------------------------------------------------------
# 4. Django Specific Files
# -----------------------------------------------------------------
# SQLite database file (if you switch to MySQL, this can be removed)
db.sqlite3

# Media/User-uploaded files (these should be stored outside the repo)
/media

# Static files generated by collectstatic (only needed on deployment server)
/staticfiles/

# -----------------------------------------------------------------
# 5. Dependency Management (Optional, depending on workflow)
# -----------------------------------------------------------------
# If you use Poetry or other package managers:
poetry.lock

# -----------------------------------------------------------------
# 6. Docker and Sensitive Data
# -----------------------------------------------------------------
# Ignore environment variables containing secrets/credentials
.env

# Docker files (logs, history, etc.)
# If you build any images or temporary containers:
*.dockerbuild